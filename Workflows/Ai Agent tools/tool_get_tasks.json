        "supabaseApi": {
          "id": "WLH1xOtq0dhre1iC",
          "name": "Zane.moore575 Supabase"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst statusCode = response.statusCode || 200;\nconst body = response.body;\n\nif (statusCode >= 400) {\n  return [{\n    json: {\n      success: false,\n      error: `Supabase returned ${statusCode}`,\n      details: body,\n      tool: 'get_tasks'\n    }\n  }];\n}\n\nlet tasks = [];\ntry {\n  if (typeof body === 'string') {\n    tasks = JSON.parse(body);\n  } else if (Array.isArray(body)) {\n    tasks = body;\n  } else if (body && typeof body === 'object') {\n    tasks = body.data || body.tasks || [body];\n  }\n} catch (e) {\n  tasks = [];\n}\n\nconst formatted = tasks.map(t => ({\n  task: t.task,\n  completed: t.completed,\n  urgency: t.urgency,\n  due_date: t.due_date,\n  created_at: t.created_at,\n  memory_id: t.memory_id\n}));\n\nreturn [{\n  json: {\n    success: true,\n    count: formatted.length,\n    tasks: formatted,\n    tool: 'get_tasks',\n    message: formatted.length > 0 \n      ? `Found ${formatted.length} tasks` \n      : 'No tasks found'\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [780, 300],
      "id": "format-response",
      "name": "Format Response"
