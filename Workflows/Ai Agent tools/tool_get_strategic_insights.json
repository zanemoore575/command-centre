    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst statusCode = response.statusCode || 200;\nconst body = response.body;\n\nif (statusCode >= 400) {\n  return [{\n    json: {\n      success: false,\n      error: `Supabase returned ${statusCode}`,\n      details: body,\n      tool: 'get_strategic_insights'\n    }\n  }];\n}\n\nlet insights = [];\ntry {\n  if (typeof body === 'string') {\n    insights = JSON.parse(body);\n  } else if (Array.isArray(body)) {\n    insights = body;\n  } else if (body && typeof body === 'object') {\n    insights = body.data || body.insights || [body];\n  }\n} catch (e) {\n  insights = [];\n}\n\nconst formatted = insights.map(i => ({\n  insight: i.insight,\n  category: i.category,\n  importance: i.importance,\n  actionable: i.actionable,\n  created_at: i.created_at,\n  memory_id: i.memory_id\n}));\n\nreturn [{\n  json: {\n    success: true,\n    count: formatted.length,\n    insights: formatted,\n    tool: 'get_strategic_insights',\n    message: formatted.length > 0 \n      ? `Found ${formatted.length} strategic insights` \n      : 'No strategic insights found matching your criteria'\n  }\n}];"
      },
